# SmartUdan — Backend Environment Variables
# Copy this file to .env and fill in your values
# cp backend/.env.example backend/.env

APP_NAME=SmartUdan
DEBUG=True

# Redis (used for caching predictions)
REDIS_URL=redis://localhost:6379

# Model
MODEL_PATH=models/lgbm_model.pkl

# Google Flights via SerpAPI (required for daily live price fetch)
# Sign up: https://serpapi.com/ — free tier includes limited searches/month
SERPAPI_API_KEY=

# Provider: auto (default), google_flights, or skyscanner
FLIGHT_PRICE_PROVIDER=google_flights
GOOGLE_FLIGHTS_CURRENCY=INR
GOOGLE_FLIGHTS_GL=in
GOOGLE_FLIGHTS_HL=en
SERPAPI_TIMEOUT_SECONDS=45
FLIGHT_FETCH_DELAY_SECONDS=1.0

# Legacy Skyscanner fallback (optional)
SKYSCANNER_RAPIDAPI_KEY=

# CORS — frontend URL(s); add your Railway frontend URL in production
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Cache settings
CACHE_TTL_SECONDS=21600
PRICE_STORE_TTL_DAYS=90

# Festive data
FESTIVE_ARCHIVE_PATH=data/festive_prices_archive.json

# Monthly live snapshot (25 routes × 7 days = 175 SerpAPI calls, fits 250/mo plan)
MONTHLY_FETCH_DAY=1
MONTHLY_FETCH_WEEK_DAYS=7
MONTHLY_FETCH_ROUTE_COUNT=25
# Optional: force week start (e.g. 2026-06-01). Empty = auto (next month if mid-month run)
MONTHLY_FETCH_ANCHOR_DATE=
