# SmartUdan — Backend Environment Variables
# Copy this file to .env and fill in your values
# cp backend/.env.example backend/.env

APP_NAME=SmartUdan
DEBUG=True

# Redis (used for caching predictions)
REDIS_URL=redis://localhost:6379

# Model
MODEL_PATH=models/lgbm_model.pkl

# Skyscanner via RapidAPI (optional — leave blank to use simulated prices)
SKYSCANNER_RAPIDAPI_KEY=

# CORS — frontend URL
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Cache settings
CACHE_TTL_SECONDS=21600
PRICE_STORE_TTL_DAYS=90

# Festive data
FESTIVE_ARCHIVE_PATH=data/festive_prices_archive.json

# Daily fetch cron (19:30 UTC = 1 AM IST)
DAILY_FETCH_CRON=30 19 * * *
